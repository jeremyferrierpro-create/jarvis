# Copiez ce fichier en .env et renseignez vos clés.
# Ne commitez JAMAIS le fichier .env sur GitHub.

# --- IA (au moins une clé recommandée) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
